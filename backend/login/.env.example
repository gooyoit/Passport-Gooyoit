APP_NAME="Gooyoit Passport"
DEBUG=true
DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/passport
REDIS_URL=redis://127.0.0.1:6379/0
SECRET_KEY=change-me-in-production-with-at-least-32-bytes
JWT_ISSUER=gooyoit-passport
COOKIE_SECURE=false
FRONTEND_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173","https://passport.gooyoit.com"]

# 邮箱发送
RESEND_API_KEY=

# WebAuthn / Passkey
# RP_ID: 域名安全边界，必须是当前页面 hostname 的后缀或完全匹配
#   本地开发用 localhost，生产环境改为实际域名（如 passport.gooyoit.com）
WEBAUTHN_RP_ID=localhost
# RP_NAME: 纯展示名，在浏览器 Passkey 弹窗中显示
WEBAUTHN_RP_NAME=Gooyoit Passport
# RP_ORIGIN: 请求来源的完整 origin（含协议），用于校验 clientDataJSON
WEBAUTHN_RP_ORIGIN=http://localhost:5173
